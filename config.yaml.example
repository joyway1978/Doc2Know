# Doc2Know 配置文件
# 复制此文件为 config.yaml 并修改为你的配置

# LLM API 配置
llm:
  # API 基础 URL
  # 默认使用 OpenAI API，可替换为其他兼容 OpenAI API 的服务
  # 例如："https://api.deepseek.com/v1" 或 "https://api.moonshot.cn/v1"
  base_url: "https://copilot.weibo.com/v1"

  # API 密钥（必填）
  # 从 OpenAI 或其他服务提供商获取
  # 也可以通过环境变量 DOCS2KNOW_API_KEY 设置
  api_key: "your-api-key-here"

  # 使用的模型名称
  # 可选值：gpt-3.5-turbo, gpt-4, gpt-4-turbo 等
  model: "wecode-agent-max"

# 路径配置
paths:
  # 输入目录：存放待转换的 Word 文档
  # 支持 .docx 和 .doc 格式
  # 也可以通过环境变量 DOCS2KNOW_RAW_DIR 设置
  raw_dir: "./raw_docs"

  # 输出目录：存放生成的 Markdown 文件
  # 生成的文件结构：
  #   output/
  #   ├── topics/     # 文档主题文件
  #   └── index.md    # 索引文件
  # 也可以通过环境变量 DOCS2KNOW_OUTPUT_DIR 设置
  output_dir: "./output"

# 处理配置
processing:
  # 文档分块大小（字符数）
  # 当文档超过此大小时，会分块处理后再合并
  # 较大的值可以减少 API 调用次数，但可能超出模型上下文限制
  # 建议范围：2000-8000
  chunk_size: 4000

  # 最大并发处理数
  # 同时处理的文档数量
  # 根据你的 API 速率限制调整
  max_concurrent: 3
